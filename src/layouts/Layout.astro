---
import '../styles/global.css';
import { asset, optimizedImage } from '../lib/assets';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Curso de Importación | ProBusiness',
  description = 'Aprende a importar desde China y crea un negocio rentable en Perú. Paso a paso, sin complicaciones y desde cero.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#000000" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={optimizedImage('/images/sections/02-hero/hero-cajas.png')} />
    <link rel="icon" type="image/svg+xml" href={asset('/favicon.png')} />
    <link rel="preconnect" href="https://cdn.probusiness.pe" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Epilogue:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Sora:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <script is:inline>
      (function () {
        var nav = performance.getEntriesByType('navigation')[0];
        if (nav && nav.type === 'reload') {
          if (window.location.hash) {
            history.replaceState(null, '', window.location.pathname + window.location.search);
          }
          window.scrollTo(0, 0);
        }
      })();
    </script>
  </head>
  <body class="min-h-screen bg-black text-white antialiased">
    <slot />
  </body>
</html>
