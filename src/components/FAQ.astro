---
const faqs = [
  { q: '¿Necesito experiencia para tomar el curso?', a: 'No, el curso está diseñado para personas sin experiencia previa en importación. Te guiamos desde cero.' },
  { q: '¿Cuánto dinero necesito para empezar?', a: 'Depende del producto que elijas importar. En el curso aprenderás a calcular costos reales y a iniciar con el capital adecuado.' },
  { q: '¿El curso es en vivo o grabado?', a: 'El curso es en vivo con clases intensivas de 2 semanas, además tendrás acceso a grabaciones.' },
  { q: '¿Qué pasa después de terminar el curso?', a: 'Tendrás acceso a la comunidad PRO BUSINESS, soporte personalizado y acceso a nuestra carga consolidada.' },
  { q: '¿Cómo sé qué producto importar para no perder dinero?', a: 'Aprenderás metodologías de búsqueda de productos rentables y validación antes de invertir.' },
  { q: '¿Qué pasa si tengo problemas con Aduanas o mi mercadería?', a: 'Te enseñamos todo el proceso aduanero y te brindamos soporte para resolver situaciones comunes.' },
  { q: '¿Qué pasa si me estafan o el proveedor no es confiable?', a: 'Aprenderás a identificar proveedores confiables y a negociar de forma segura con respaldo de nuestra experiencia.' },
];

const left = faqs.slice(0, 3);
const right = faqs.slice(3, 6);
const center = faqs.slice(6);
---

<section id="faq" class="site-section relative">
  <div class="site-container">
    <h2 class="mb-10 text-center font-sora text-3xl font-bold text-white md:text-4xl lg:mb-12 lg:text-5xl xl:text-6xl">
      Preguntas frecuentes
    </h2>

    <div class="grid gap-4 lg:grid-cols-2">
      <div class="space-y-4">
        {left.map((faq) => (
          <details class="group rounded-[20px] border border-white/10 bg-white/5 open:border-probusiness-naranja/30">
            <summary class="flex cursor-pointer items-center justify-between gap-4 p-5 font-epilogue text-base font-medium text-white lg:p-6 lg:text-lg">
              {faq.q}
              <span class="shrink-0 text-2xl text-probusiness-naranja transition-transform group-open:rotate-90">›</span>
            </summary>
            <div class="border-t border-white/10 px-5 pb-5 pt-3 lg:px-6 lg:pb-6">
              <p class="font-epilogue text-sm leading-relaxed text-white/70 lg:text-base">{faq.a}</p>
            </div>
          </details>
        ))}
      </div>
      <div class="space-y-4">
        {right.map((faq) => (
          <details class="group rounded-[20px] border border-white/10 bg-white/5 open:border-probusiness-naranja/30">
            <summary class="flex cursor-pointer items-center justify-between gap-4 p-5 font-epilogue text-base font-medium text-white lg:p-6 lg:text-lg">
              {faq.q}
              <span class="shrink-0 text-2xl text-probusiness-naranja transition-transform group-open:rotate-90">›</span>
            </summary>
            <div class="border-t border-white/10 px-5 pb-5 pt-3 lg:px-6 lg:pb-6">
              <p class="font-epilogue text-sm leading-relaxed text-white/70 lg:text-base">{faq.a}</p>
            </div>
          </details>
        ))}
      </div>
      {center.map((faq) => (
        <details class="group rounded-[20px] border border-white/10 bg-white/5 open:border-probusiness-naranja/30 lg:col-span-2">
          <summary class="flex cursor-pointer items-center justify-between gap-4 p-5 font-epilogue text-base font-medium text-white lg:p-6 lg:text-lg">
            {faq.q}
            <span class="shrink-0 text-2xl text-probusiness-naranja transition-transform group-open:rotate-90">›</span>
          </summary>
          <div class="border-t border-white/10 px-5 pb-5 pt-3 lg:px-6 lg:pb-6">
            <p class="font-epilogue text-sm leading-relaxed text-white/70 lg:text-base">{faq.a}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
