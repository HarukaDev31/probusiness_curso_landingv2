---
const benefits = [
  { title: '2 Semanas de clases intensivas', icon: '/images/sections/11-benefits/icon-semanas.png' },
  { title: 'Soporte y asesoría personalizada', icon: '/images/sections/11-benefits/icon-soporte.png' },
  { title: 'Acceso a la comunidad PRO BUSINESS', icon: '/images/sections/11-benefits/icon-comunidad.png' },
  { title: 'Acceso a nuestra Carga Consolidada', icon: '/images/sections/11-benefits/icon-carga.png' },
];
---

<section class="site-section border-t border-white/10 bg-[#111]">
  <div class="site-container">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4 lg:gap-10">
      {benefits.map((b) => (
        <div class="flex flex-col items-center text-center">
          <img src={b.icon} alt="" class="mb-5 h-24 w-auto object-contain lg:mb-6 lg:h-32" aria-hidden="true" loading="lazy" />
          <p class="max-w-[220px] font-epilogue text-sm font-medium leading-snug text-white lg:text-base">
            {b.title}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
