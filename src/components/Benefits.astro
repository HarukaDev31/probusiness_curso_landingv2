---
import { optimizedImage } from '../lib/assets';

const sprite = optimizedImage('/images/sections/11-benefits/icon-semanas.png');

const benefits = [
  {
    iconW: 384,
    iconH: 292,
    spriteW: '210.04%',
    spriteH: '184.19%',
    spriteLeft: '-5.1%',
    spriteTop: '-0.04%',
    lines: [
      [{ text: '2 Semanas', medium: true }],
      [{ text: 'de clases', medium: false }],
      [{ text: 'intensivas', medium: false }],
    ],
  },
  {
    iconW: 385,
    iconH: 268,
    spriteW: '210.04%',
    spriteH: '201.38%',
    spriteLeft: '-99.01%',
    spriteTop: '-0.05%',
    lines: [
      [{ text: 'Acceso a la', medium: false }],
      [{ text: 'comunidad', medium: false }],
      [{ text: 'PRO BUSINESS', medium: true }],
    ],
  },
  {
    iconW: 385,
    iconH: 268,
    spriteW: '210.04%',
    spriteH: '201.38%',
    spriteLeft: '-99.01%',
    spriteTop: '-100.74%',
    lines: [
      [{ text: 'Soporte y', medium: false }],
      [{ text: 'asesoría', medium: false }],
      [{ text: 'personalizada', medium: true }],
    ],
  },
  {
    iconW: 385,
    iconH: 264,
    spriteW: '210.04%',
    spriteH: '204.1%',
    spriteLeft: '-5.1%',
    spriteTop: '-104.26%',
    lines: [
      [{ text: 'Acceso a', medium: false }],
      [
        { text: 'nuestra ', medium: false },
        { text: 'Carga', medium: true },
      ],
      [{ text: 'Consolidada', medium: true }],
    ],
  },
];
---

<section class="benefits-section" aria-label="Beneficios del curso">
  <div class="benefits-grid">
    {
      benefits.map((benefit) => (
        <article class="benefits-item">
          <div
            class="benefits-item__icon-wrap"
            style={`--icon-w: ${benefit.iconW}; --icon-h: ${benefit.iconH};`}
          >
            <img
              src={sprite}
              alt=""
              class="benefits-item__icon"
              style={`width: ${benefit.spriteW}; height: ${benefit.spriteH}; left: ${benefit.spriteLeft}; top: ${benefit.spriteTop};`}
              width={benefit.iconW}
              height={benefit.iconH}
              aria-hidden="true"
              loading="lazy"
            />
          </div>
          <div class="benefits-item__text">
            {benefit.lines.map((line) => (
              <p class="benefits-item__line">
                {line.map((part) => (
                  <span class={part.medium ? 'font-medium' : 'font-normal'}>
                    {part.text}
                  </span>
                ))}
              </p>
            ))}
          </div>
        </article>
      ))
    }
  </div>
</section>

<style>
  .benefits-section {
    background-color: #242424;
    width: 100%;
    padding: 0;
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0;
    width: 100%;
    max-width: var(--site-max);
    margin-inline: auto;
  }

  .benefits-item {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: clamp(0.65rem, 3vw, 1rem);
    padding: clamp(1.25rem, 4.5vw, 1.75rem) clamp(0.65rem, 3vw, 1rem);
  }

  @media (max-width: 1023px) {
    .benefits-item:nth-child(odd) {
      border-right: 2px solid #000;
    }

    .benefits-item:nth-child(-n + 2) {
      border-bottom: 2px solid #000;
    }
  }

  .benefits-item__icon-wrap {
    position: relative;
    overflow: hidden;
    width: min(100%, clamp(4.75rem, 22vw, 6.5rem));
    aspect-ratio: var(--icon-w) / var(--icon-h);
    flex-shrink: 0;
  }

  .benefits-item__icon {
    position: absolute;
    max-width: none;
    pointer-events: none;
  }

  .benefits-item__text {
    color: #fff;
    font-family: var(--font-epilogue);
    font-size: clamp(0.72rem, 3.1vw, 0.95rem);
    letter-spacing: -0.01em;
    line-height: 1.05;
    max-width: 9.5rem;
  }

  .benefits-item__line {
    margin: 0;
    word-break: break-word;
  }

  @media (min-width: 1024px) {
    .benefits-section {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 350px;
      padding: clamp(2rem, 3.5vw, 3.5rem) clamp(1rem, 4vw, 4.5rem);
    }

    .benefits-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      align-items: center;
    }

    .benefits-item {
      min-height: 100%;
      gap: clamp(1.5rem, 1.94vw, 4.8125rem);
      padding: 0 0.75rem;
    }

    .benefits-item:not(:last-child)::after {
      content: '';
      position: absolute;
      top: 50%;
      right: 0;
      transform: translateY(-50%);
      width: 3px;
      height: 76.7%;
      background-color: #4d4d4d;
    }

    .benefits-item__icon-wrap {
      width: min(100%, clamp(8.5rem, calc(var(--icon-w) / 3973 * 100vw), 24rem));
    }

    .benefits-item__text {
      font-size: clamp(1.05rem, 1.25vw, 1.25rem);
      line-height: 0.98;
      max-width: clamp(12rem, 13.5vw, 16rem);
    }
  }
</style>
