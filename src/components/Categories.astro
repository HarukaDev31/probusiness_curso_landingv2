---
import ResponsiveImage from './ResponsiveImage.astro';
import { asset } from '../lib/assets';

const cat = (file: string) => `/images/sections/07-categories/${file}`;
---

<section class="categories-section relative overflow-hidden">
  <div class="relative z-10">
    <h2
      class="categories-heading site-container text-center font-epilogue font-medium leading-[0.95] tracking-[-0.06em] text-black"
    >
      <span class="block">
        Ellos ya están <span class="font-semibold text-probusiness-naranja">importando</span>
      </span>
      <span class="block font-semibold text-probusiness-naranja">con éxito</span>
    </h2>

    <div class="categories-grid">
      <div class="cat-cell">
        <ResponsiveImage src={cat('1.png')} alt="Importador mostrando producto" class="cat-photo" sizes="(max-width: 768px) 45vw, 18vw" loading="lazy" />
      </div>

      <div class="cat-cell cat-cell--tecnologia">
        <img src={asset(cat('2.svg'))} alt="" class="cat-arrow cat-arrow--tecnologia" aria-hidden="true" />
        <p class="cat-label">Tecnología</p>
      </div>

      <div class="cat-cell">
        <ResponsiveImage src={cat('3.png')} alt="Emprendedor en almacén" class="cat-photo" sizes="(max-width: 768px) 45vw, 18vw" loading="lazy" />
      </div>

      <div class="cat-cell">
        <ResponsiveImage src={cat('4.png')} alt="Importadora en centro logístico" class="cat-photo" sizes="(max-width: 768px) 45vw, 18vw" loading="lazy" />
      </div>

      <div class="cat-cell">
        <ResponsiveImage src={cat('5.png')} alt="Emprendedora con vehículo" class="cat-photo" sizes="(max-width: 768px) 45vw, 18vw" loading="lazy" />
      </div>

      <div class="cat-cell">
        <ResponsiveImage src={cat('6.png')} alt="Importador frente a camión" class="cat-photo" sizes="(max-width: 768px) 45vw, 18vw" loading="lazy" />
      </div>

      <div class="cat-cell">
        <ResponsiveImage src={cat('7.png')} alt="Pareja emprendedora" class="cat-photo" sizes="(max-width: 768px) 45vw, 18vw" loading="lazy" />
      </div>

      <div class="cat-cell">
        <ResponsiveImage src={cat('8.png')} alt="Importadora con calzado" class="cat-photo" sizes="(max-width: 768px) 45vw, 18vw" loading="lazy" />
      </div>

      <div class="cat-cell cat-cell--vehiculos">
        <ResponsiveImage src={cat('9.png')} alt="" class="cat-arrow cat-arrow--vehiculos" sizes="40vw" aria-hidden="true" responsive={false} />
        <p class="cat-label">Vehículos</p>
      </div>

      <div class="cat-cell">
        <ResponsiveImage src={cat('10.png')} alt="Importador con producto" class="cat-photo" sizes="(max-width: 768px) 45vw, 18vw" loading="lazy" />
      </div>

      <div class="cat-cell cat-cell--juguetes">
        <img src={asset(cat('11.svg'))} alt="" class="cat-arrow cat-arrow--juguetes" aria-hidden="true" />
        <p class="cat-label cat-label--muted">Juguetes</p>
      </div>

      <div class="cat-cell">
        <ResponsiveImage src={cat('12.png')} alt="Emprendedora con caja" class="cat-photo" sizes="(max-width: 768px) 45vw, 18vw" loading="lazy" />
      </div>

      <div class="cat-cell">
        <ResponsiveImage src={cat('13.png')} alt="Importadora con producto" class="cat-photo" sizes="(max-width: 768px) 45vw, 18vw" loading="lazy" />
      </div>

      <div class="cat-cell">
        <ResponsiveImage src={cat('14.png')} alt="Importador en almacén" class="cat-photo" sizes="(max-width: 768px) 45vw, 18vw" loading="lazy" />
      </div>

      <div class="cat-cell cat-cell--maletas">
        <img src={asset(cat('2.svg'))} alt="" class="cat-arrow cat-arrow--maletas" aria-hidden="true" />
        <p class="cat-label cat-label--right">Maletas</p>
      </div>

      <div class="cat-cell">
        <ResponsiveImage src={cat('16.png')} alt="Emprendedor importador" class="cat-photo" sizes="(max-width: 768px) 45vw, 18vw" loading="lazy" />
      </div>

      <div class="cat-cell">
        <ResponsiveImage src={cat('17.png')} alt="Importador en depósito" class="cat-photo" sizes="(max-width: 768px) 45vw, 18vw" loading="lazy" />
      </div>

      <div class="cat-cell cat-cell--joyas">
        <img src={asset(cat('18.svg'))} alt="" class="cat-arrow cat-arrow--joyas" aria-hidden="true" />
        <p class="cat-label">Joyas</p>
      </div>

      <div class="cat-cell">
        <ResponsiveImage src={cat('19.png')} alt="Importador satisfecho" class="cat-photo" sizes="(max-width: 768px) 45vw, 18vw" loading="lazy" />
      </div>

      <div class="cat-cell cat-cell--ymas">
        <p class="cat-label">Y más</p>
      </div>

      <div class="cat-cell cat-cell--mobile-extra">
        <ResponsiveImage src={cat('20.avif')} alt="" class="cat-photo" sizes="45vw" loading="lazy" aria-hidden="true" />
      </div>
    </div>
  </div>
</section>

<style>
  .categories-heading {
    padding-top: clamp(3rem, 6vw, 5rem);
    padding-bottom: clamp(2rem, 4vw, 3.5rem);
    font-size: clamp(2.25rem, 4vw, 6.25rem);
  }

  .categories-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 0;
    width: 100%;
  }

  .cat-cell {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    container-type: size;
  }

  .cat-cell :global(picture:has(.cat-photo)) {
    display: block;
    width: 100%;
    height: 100%;
  }

  .cat-photo,
  .cat-cell :global(.cat-photo) {
    display: block;
    height: 100%;
    width: 100%;
    object-fit: cover;
  }

  .cat-cell :global(picture:has(.cat-arrow)) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .cat-cell :global(.cat-arrow) {
    max-width: none;
    object-fit: contain;
  }

  .cat-label {
    position: absolute;
    z-index: 2;
    bottom: 0;
    left: 0;
    padding: 8.5cqw;
    font-family: var(--font-epilogue);
    font-size: 13.75cqw;
    font-weight: 600;
    line-height: 1.03;
    letter-spacing: -0.06em;
    color: #fff;
  }

  .cat-label--muted {
    color: #c4c4c4;
  }

  .cat-label--right {
    right: 0;
    left: auto;
    text-align: right;
  }

  .cat-arrow,
  .cat-cell :global(.cat-arrow) {
    position: absolute;
    z-index: 1;
    pointer-events: none;
    max-width: none;
    object-fit: contain;
  }

  /* Tecnología — naranja sólido + flecha grande */
  .cat-cell--tecnologia {
    background: #ff5410;
  }

  .cat-arrow--tecnologia,
  .cat-cell :global(.cat-arrow--tecnologia) {
    width: 95%;
    opacity: 0.35;
  }

  /* Vehículos — negro + flecha naranja tenue arriba-derecha */
  .cat-cell--vehiculos {
    background: #000;
  }

  .cat-arrow--vehiculos,
  .cat-cell :global(.cat-arrow--vehiculos) {
    top: 0;
    right: 0;
    width: 90%;
    opacity: 0.22;
  }

  /* Juguetes — blanco + flecha gris apuntando derecha */
  .cat-cell--juguetes {
    background: #fff;
  }

  .cat-arrow--juguetes,
  .cat-cell :global(.cat-arrow--juguetes) {
    top: 50%;
    left: -8%;
    width: 72%;
    transform: translateY(-50%);
    opacity: 1;
  }

  /* Maletas — naranja + flecha grande arriba-izquierda */
  .cat-cell--maletas {
    background: #ff5410;
  }

  .cat-arrow--maletas,
  .cat-cell :global(.cat-arrow--maletas) {
    top: -8%;
    right: -20%;
    width: 115%;
    transform: rotate(180deg) scaleY(-1);
    opacity: 0.35;
  }

  /* Joyas — gris + flecha */
  .cat-cell--joyas {
    background: #656565;
  }

  .cat-arrow--joyas,
  .cat-cell :global(.cat-arrow--joyas) {
    bottom: -8%;
    left: -10%;
    width: 72%;
    transform: rotate(180deg);
    opacity: 0.55;
  }

  /* Y más — gris claro, sin flecha */
  .cat-cell--ymas {
    background: #9c9c9c;
  }

  .cat-cell--mobile-extra {
    display: none;
  }

  @media (max-width: 1023px) {
    .categories-heading {
      font-size: clamp(1.75rem, 7.5vw, 2.5rem);
      padding-top: clamp(2rem, 5vw, 3rem);
      padding-bottom: clamp(1.5rem, 4vw, 2.5rem);
    }

    .categories-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .cat-cell--mobile-extra {
      display: block;
    }
  }
</style>
