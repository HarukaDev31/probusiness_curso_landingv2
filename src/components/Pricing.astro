<script>
  async function bindCopyButton(buttonId, labelId) {
    const button = document.getElementById(buttonId);
    const label = document.getElementById(labelId);
    if (!button) return;

    button.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText("CURSOPRO");
        if (label) {
          label.textContent = "¡Copiado!";
          setTimeout(() => {
            label.textContent = "COPIAR";
          }, 2000);
        }
      } catch {
        /* noop */
      }
    });
  }

  bindCopyButton("copy-code", "copy-label");
  bindCopyButton("copy-code-mobile", "copy-label-mobile");

  const target = new Date();
  target.setDate(target.getDate() + 2);
  target.setHours(target.getHours() + 15);
  target.setMinutes(37);
  target.setSeconds(28);

  function pad(n) {
    return String(n).padStart(2, "0");
  }

  function tick() {
    const diff = Math.max(0, target.getTime() - Date.now());
    const s = Math.floor(diff / 1000);
    const values = {
      days: Math.floor(s / 86400),
      hours: Math.floor((s % 86400) / 3600),
      minutes: Math.floor((s % 3600) / 60),
      seconds: s % 60,
    };

    document.querySelectorAll("[data-unit]").forEach((el) => {
      const unit = el.getAttribute("data-unit");
      if (unit) el.textContent = pad(values[unit] ?? 0);
    });
  }

  tick();
  setInterval(tick, 1000);
</script>
