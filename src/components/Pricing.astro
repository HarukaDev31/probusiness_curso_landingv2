---
const temario = [
  'Búsqueda de productos rentables',
  'Proveedores confiables en China',
  'Negociación con proveedores',
  'Cálculo de costos de importación',
  'Logística internacional',
  'Trámites aduaneros',
  'Carga consolidada y envíos',
  'Formas de pago internacionales',
  'Proceso completo de importación',
  'Estrategias para iniciar tu negocio importador',
];
---

<section id="planes" class="site-section relative">
  <div class="site-container">
    <h2 class="mb-8 text-center font-sora text-lg font-semibold tracking-[0.25em] text-white/80 uppercase lg:mb-12 lg:text-2xl">
      Temario del Curso
    </h2>

    <div class="relative mx-auto max-w-5xl">
      <div class="grid gap-6 lg:grid-cols-[1fr_0.72fr] lg:items-start lg:gap-8">
        <div class="card-glow relative z-10 overflow-hidden rounded-[20px] bg-probusiness-naranja">
          <div class="flex h-14 items-center justify-center gap-2 bg-probusiness-orange-header lg:h-16">
            <svg class="h-5 w-5 text-white lg:h-6 lg:w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
            <span class="font-epilogue text-sm font-semibold tracking-widest text-white uppercase lg:text-base">Ahora</span>
          </div>

          <div class="p-6 lg:p-8">
            <p class="mb-2 font-sora text-xs font-medium tracking-widest text-white uppercase lg:text-sm">Conviértete en un</p>
            <h3 class="font-sora text-3xl font-bold text-white lg:text-4xl xl:text-5xl">Importador</h3>
            <div class="mb-6 flex flex-wrap items-center gap-3">
              <h3 class="font-sora text-3xl font-bold text-black lg:text-4xl xl:text-5xl">Certificado</h3>
              <span class="rounded-2xl bg-black px-3 py-1 font-sora text-lg font-semibold text-gradient-pro lg:px-4 lg:text-2xl">PRO</span>
            </div>

            <div class="mb-8 flex items-start gap-1">
              <span class="font-sora text-xl font-bold text-white lg:text-2xl">S/</span>
              <span class="font-sora text-6xl font-bold leading-none text-black lg:text-7xl xl:text-8xl">550</span>
              <span class="font-sora text-2xl font-bold text-white lg:text-3xl">,00</span>
            </div>

            <hr class="mb-6 border-white/30 lg:mb-8" />

            <ol class="mb-8 space-y-2 font-epilogue text-sm text-white lg:space-y-3 lg:text-base">
              {temario.map((item, i) => (
                <li class="flex gap-3">
                  <span class="font-semibold text-black">{i + 1}.</span>
                  {item}
                </li>
              ))}
            </ol>

            <a
              href="#contacto"
              class="block w-full rounded-[36px] bg-white py-4 text-center font-epilogue text-lg font-bold text-probusiness-naranja transition-opacity hover:opacity-90 lg:text-xl"
            >
              Quiero este plan
            </a>
          </div>
        </div>

        <div class="relative overflow-hidden rounded-[20px] bg-[#2c2c2c] lg:mt-16 xl:mt-20">
          <div class="flex h-14 items-center justify-center gap-2 bg-[#1c1c1c] lg:h-16">
            <svg class="h-5 w-5 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
            <span class="font-epilogue text-sm font-semibold tracking-widest text-white/50 uppercase lg:text-base">Antes</span>
          </div>
          <div class="p-6 lg:p-8">
            <p class="mb-2 font-sora text-xs font-medium tracking-widest text-zinc-500 uppercase lg:text-sm">Conviértete en un</p>
            <h3 class="font-sora text-2xl font-bold text-zinc-500 lg:text-3xl xl:text-4xl">Importador</h3>
            <h3 class="mb-6 font-sora text-2xl font-bold text-zinc-600 lg:text-3xl xl:text-4xl">Certificado</h3>
            <div class="mb-4 flex items-start gap-1">
              <span class="font-sora text-lg font-bold text-zinc-500 lg:text-xl">S/</span>
              <span class="font-sora text-4xl font-bold text-zinc-500 line-through lg:text-5xl xl:text-6xl">950</span>
              <span class="font-sora text-xl font-bold text-zinc-500 lg:text-2xl">,00</span>
            </div>
            <p class="font-epilogue text-sm text-zinc-500 lg:text-base">Precio sin descuento</p>
          </div>
        </div>
      </div>
    </div>

    <div class="relative mx-auto mt-12 max-w-4xl text-center lg:mt-16">
      <p class="mb-6 inline-block rounded-[20px] bg-probusiness-naranja px-5 py-3 font-epilogue text-sm font-bold uppercase tracking-wide text-white lg:px-8 lg:py-4 lg:text-xl">
        Promoción por tiempo limitado
      </p>

      <p class="mb-6 font-sora text-lg font-medium text-white lg:mb-8 lg:text-2xl xl:text-3xl">
        Obtén un descuento adicional usando el código:
      </p>

      <div class="relative inline-flex flex-wrap items-center justify-center gap-4">
        <img
          src="/images/sections/09-pricing/mascota.png"
          alt=""
          class="pointer-events-none absolute -left-12 -top-6 hidden h-28 w-28 object-contain lg:block xl:-left-20 xl:h-36 xl:w-36"
          aria-hidden="true"
          loading="lazy"
        />
        <div class="inline-flex items-center gap-3 rounded-[20px] border-2 border-probusiness-naranja bg-zinc-900 px-5 py-3 lg:gap-4 lg:px-8 lg:py-4">
          <span class="font-sora text-2xl font-bold text-gradient-pro lg:text-4xl xl:text-5xl">CURSOPRO</span>
          <button
            id="copy-code"
            type="button"
            class="inline-flex items-center gap-2 rounded-xl bg-probusiness-naranja px-4 py-2 font-epilogue text-sm font-bold text-white transition-opacity hover:opacity-90"
          >
            <img id="copy-icon" src="/images/sections/09-pricing/icon-copy.svg" alt="" class="h-4 w-4 object-contain" aria-hidden="true" />
            <span id="copy-label">COPIAR</span>
          </button>
        </div>
      </div>

      <p class="mt-6 font-sora text-base font-semibold text-probusiness-naranja lg:mt-8 lg:text-xl">*CUPOS LIMITADOS</p>
    </div>
  </div>
</section>

<script>
  document.getElementById('copy-code')?.addEventListener('click', async () => {
    const label = document.getElementById('copy-label');
    try {
      await navigator.clipboard.writeText('CURSOPRO');
      if (label) {
        label.textContent = '¡Copiado!';
        setTimeout(() => { label.textContent = 'COPIAR'; }, 2000);
      }
    } catch { /* noop */ }
  });
</script>
