</section>

<style>
  .pricing-hero-bg {
    /* Franja visible: 20%–80% de la imagen (60% de altura Figma ≈ 1181px @ 3973px) */
    height: min(29.7vw, 1181px);
    overflow: hidden;
  }

  .pricing-hero-bg img {
    position: absolute;
    left: 0;
    width: 100%;
    height: calc(100% / 0.6);
    top: calc(-100% / 3);
    object-fit: cover;
    object-position: center center;
  }

  .pricing-hero-fade {
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0) 0%,
      rgba(0, 0, 0, 0.89) 26.75%,
      rgba(0, 0, 0, 0.98) 50.43%,
      rgba(0, 0, 0, 0.93) 72.22%,
      #000 100%
    );
  }

  .pricing-hero-fade-top {
    height: min(29.7vw, 1181px);
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.15) 0%,
      rgba(0, 0, 0, 0.72) 45%,
      #000 100%
    );
  }

  .pricing-cards {
    position: relative;
  }

  .pricing-cards--desktop {
    display: none;
    min-height: 620px;
  }

  .pricing-promo--desktop,
  .pricing-promo--mobile {
    display: none;
  }

  .pricing-card {
    border-radius: 6px;
    overflow: hidden;
  }

  .pricing-card--ahora {
    position: relative;
    z-index: 2;
    width: min(100%, 550px);
    background: #ff6a29;
  }

  .pricing-card__badge {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    min-height: 3.25rem;
    background: #ee4815;
    font-family: var(--font-epilogue);
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #fff;
  }

  .pricing-card__badge--muted {
    background: #1c1c1c;
    color: rgba(255, 255, 255, 0.45);
  }

  .pricing-card__cta--muted {
    border-radius: 999px;
    background: #3a3a3a;
    color: rgba(255, 255, 255, 0.35);
    cursor: not-allowed;
  }

  .pricing-cards--desktop .pricing-card__body {
    position: relative;
    overflow: hidden;
  }

  .pricing-cards--desktop .pricing-card--ahora .pricing-card__body {
    padding: 0;
  }

  .pricing-cards--desktop .pricing-card__content {
    position: relative;
    z-index: 2;
    padding: 1.5rem 1.75rem 2rem;
  }

  @media (min-width: 1024px) {
    .pricing-cards--desktop .pricing-card__content {
      padding: 2rem 2.25rem 2.5rem;
    }
  }

  .pricing-cards--desktop .pricing-card__fade {
    position: absolute;
    inset: auto 0 0;
    z-index: 1;
    height: 55%;
    pointer-events: none;
  }

  .pricing-cards--desktop .pricing-card--antes {
    position: absolute;
    top: 2.5rem;
    right: 80px;
    z-index: 1;
    width: min(78%, 350px);
    background: rgba(40, 40, 40, 0.95);
  }

  .pricing-cards--desktop .pricing-card__body {
    padding: 1.5rem 1.75rem 2rem;
  }

  .pricing-cards--desktop .pricing-card--ahora .pricing-card__body {
    padding: 0;
  }

  @media (min-width: 1024px) {
    .pricing-cards--desktop .pricing-card__body {
      padding: 2rem 2.25rem 2.5rem;
    }

    .pricing-cards--desktop .pricing-card--ahora .pricing-card__body {
      padding: 0;
    }
  }

  .pricing-card__eyebrow {
    margin-bottom: 0.35rem;
    font-family: var(--font-sora);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #fff;
  }

  .pricing-card__eyebrow--muted {
    color: rgba(255, 255, 255, 0.35);
  }

  .pricing-card__title {
    font-family: var(--font-sora);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 700;
    line-height: 1.05;
  }

  .pricing-card__title--muted {
    color: rgba(255, 255, 255, 0.35);
  }

  .pricing-card__title-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }

  .pricing-card__title-row--muted {
    margin-bottom: 1.5rem;
  }

  .pricing-card__pro {
    border-radius: 8px;
    background: #000;
    padding: 0.05rem 0.4rem;
    font-family: var(--font-sora);
    font-size: clamp(1rem, 2vw, 1.5rem);
    font-weight: 600;
    color: #ff5410;
    font-size: 2.05rem;
  }

  .pricing-card__pro--muted {
    color: rgba(255, 255, 255, 0.35);
  }

  .pricing-card__price {
    display: flex;

    gap: 0.15rem;
    margin-bottom: 1.5rem;
    font-family: var(--font-sora);
    font-weight: 700;
    color: #fff;
  }

  .pricing-card__price--muted {
    margin-bottom: 0.75rem;
    color: rgba(255, 255, 255, 0.35);
  }

  .pricing-card__currency {
    font-size: 1.25rem;
    line-height: 1.2;
  }

  .pricing-card__currency--dark {
    color: #000;
  }

  .pricing-card__amount {
    font-size: clamp(3rem, 8vw, 5rem);
    line-height: 0.9;
  }

  .pricing-card__amount--dark {
    color: #000;
  }

  .pricing-card__cents {
    font-size: 1.5rem;
    line-height: 1.2;
  }

  .pricing-card__cents--dark {
    color: #000;
  }

  .pricing-card__note {
    margin-bottom: 1.5rem;
    font-family: var(--font-epilogue);
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.35);
  }

  .pricing-card__divider {
    margin-bottom: 1.25rem;
    border: 0;
    border-top: 2px dotted rgba(255, 255, 255, 0.55);
  }

  .pricing-card__list {
    margin-bottom: 1.75rem;
    display: grid;
    gap: 0.45rem;
    font-family: var(--font-epilogue);
    font-size: 0.875rem;
    line-height: 1.35;
    color: #fff;
    -webkit-mask-image: linear-gradient(
      to bottom,
      #000 0%,
      #000 72%,
      transparent 100%
    );
    mask-image: linear-gradient(to bottom, #000 0%, #000 72%, transparent 100%);
  }

  @media (min-width: 1024px) {
    .pricing-card__list {
      font-size: 0.95rem;
      gap: 0.55rem;
    }
  }

  .pricing-card__list li {
    display: flex;
    gap: 0.5rem;
  }

