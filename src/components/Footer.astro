---
const footerStats = [
  { value: '+5000', label: 'Alumnos egresados' },
  { value: '+10', label: 'Años de experiencia' },
];
---

<footer class="border-t border-white/10 bg-black py-12 lg:py-16">
  <div class="site-container">
    <div class="mb-10 flex justify-center lg:mb-12">
      <a href="#inicio" aria-label="ProBusiness — Inicio">
        <img
          src="/images/sections/14-footer/logo-large.png"
          alt="probusiness"
          class="h-24 w-auto object-contain lg:h-32 xl:h-40"
          width="782"
          height="460"
        />
      </a>
    </div>

    <div class="mb-10 grid gap-8 sm:grid-cols-2 lg:mb-12 lg:grid-cols-4 lg:gap-10">
      <div class="flex flex-col items-center text-center">
        <img src="/images/sections/14-footer/logo-ccl.png" alt="CCL" class="mb-4 h-12 w-auto object-contain lg:h-14" loading="lazy" />
        <p class="font-epilogue text-sm font-medium text-white/80">Respaldado por la CCL</p>
      </div>

      <div class="flex flex-col items-center text-center">
        <img src="/images/sections/14-footer/icon-china.svg" alt="" class="mb-4 h-14 w-14 object-contain lg:h-16 lg:w-16" aria-hidden="true" />
        <p class="font-epilogue text-sm font-medium text-white/80">Sede propia en China</p>
      </div>

      {footerStats.map((stat) => (
        <div class="text-center">
          <p class="font-sora text-3xl font-bold text-probusiness-naranja lg:text-4xl xl:text-5xl">{stat.value}</p>
          <p class="mt-2 font-epilogue text-sm text-white/60">{stat.label}</p>
        </div>
      ))}
    </div>

    <div class="border-t border-white/10 pt-6 text-center lg:pt-8">
      <p class="font-epilogue text-sm text-white/50">2026, probusiness. Todos los derechos reservados</p>
    </div>
  </div>
</footer>
