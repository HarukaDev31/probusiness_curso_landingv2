---
import ResponsiveImage from './ResponsiveImage.astro';
import { asset } from '../lib/assets';

const footerStats = [
  { value: '+5000', label: 'Alumnos egresados' },
  { value: '+10', label: 'Años de experiencia' },
];
---

<footer class="footer">
  <div class="site-container footer__inner">
    <a href="#inicio" class="footer-brand" aria-label="ProBusiness — Inicio">
      <ResponsiveImage
        src="/images/sections/14-footer/logo-large.png"
        alt="probusiness"
        class="footer-brand__logo"
        loading="lazy"
        responsive={false}
      />
    </a>

    <div class="footer-stats">
      <div class="footer-stat">
        <ResponsiveImage
          src="/images/sections/14-footer/logo-ccl.png"
          alt="CCL"
          class="footer-stat__logo footer-stat__logo--ccl"
          loading="lazy"
          responsive={false}
        />
        <p class="footer-stat__label">Respaldado por la CCL</p>
      </div>

      <div class="footer-stat">
        <img
          src={asset('/images/sections/14-footer/icon-china.svg')}
          alt=""
          class="footer-stat__logo footer-stat__logo--china"
          aria-hidden="true"
          loading="lazy"
        />
        <p class="footer-stat__label">Sede propia en China</p>
      </div>

      {
        footerStats.map((stat) => (
          <div class="footer-stat">
            <p class="footer-stat__value">{stat.value}</p>
            <p class="footer-stat__label">{stat.label}</p>
          </div>
        ))
      }
    </div>
 
    <p class="footer-copy block text-center">2026, probusiness. Todos los derechos reservados</p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    background-color: #000;
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-areas:
      'stats stats'
      'brand copy';
    gap: clamp(1.75rem, 6vw, 2.5rem) clamp(1rem, 4vw, 1.5rem);
    padding-block: clamp(2rem, 6vw, 3rem);
  }
  .footer-brand {
    grid-area: brand;
    align-self: end;
    flex-shrink: 0;
  }

  .footer-brand__logo,
  .footer-brand :global(.footer-brand__logo) {
    display: block;
    height: clamp(3.25rem, 14vw, 4rem);
    width: auto;
    max-width: min(100%, 11rem);
    object-fit: contain;
  }

  .footer-stats {
    grid-area: stats;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(1.75rem, 6vw, 2.5rem) clamp(1rem, 4vw, 1.5rem);
  }

  .footer-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    text-align: center;
    gap: 0.65rem;
  }

  .footer-stat__logo {
    object-fit: contain;
  }

  .footer-stat__logo--ccl,
  .footer-stat :global(.footer-stat__logo--ccl) {
    height: clamp(2rem, 7vw, 2.5rem);
    width: auto;
    max-width: 4.5rem;
    object-fit: contain;
  }

  .footer-stat__logo--china {
    height: clamp(1.75rem, 5.5vw, 2.25rem);
    width: clamp(1.75rem, 5.5vw, 2.25rem);
  }

  .footer-stat__value {
    margin: 0;
    font-family: var(--font-sora);
    font-size: clamp(1.75rem, 7vw, 2.25rem);
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.03em;
    color: #fff;
  }

  .footer-stat__label {
    margin: 0;
    font-family: var(--font-epilogue);
    font-size: clamp(0.75rem, 3vw, 0.875rem);
    font-weight: 500;
    line-height: 1.25;
    color: rgba(255, 255, 255, 0.8);
  }

  .footer-copy {
    grid-area: copy;
    align-self: end;
    margin: 0;
    max-width: 11rem;
    text-align: right;
    font-family: var(--font-epilogue);
    font-size: clamp(0.625rem, 2.6vw, 0.75rem);
    font-weight: 400;
    line-height: 1.35;
    color: rgba(255, 255, 255, 0.5);
  }

  @media (min-width: 1024px) {
    .footer__inner {
      display: grid;
      grid-template-columns: minmax(0, 20rem) 1fr;
      grid-template-areas:
        'brand stats'
        'copy copy';
      align-items: center;
      gap: clamp(2rem, 4vw, 3rem) clamp(2rem, 6vw, 5rem);
      padding-block: clamp(3rem, 5vw, 4.5rem) clamp(2rem, 3vw, 2.5rem);
    }

    .footer-brand {
      align-self: center;
      justify-self: start;
    }

    .footer-brand__logo,
    .footer-brand :global(.footer-brand__logo) {
      height: clamp(5.5rem, 7vw, 7rem);
      max-width: 20rem;
    }

    .footer-stats {
      display: flex;
      justify-content: flex-end;
      align-items: flex-start;
      gap: clamp(2rem, 4vw, 4rem);
    }

    .footer-stat {
      flex: 0 0 auto;
      min-width: clamp(6.5rem, 9vw, 9.5rem);
      gap: 0.75rem;
    }

    .footer-stat__logo--ccl,
    .footer-stat :global(.footer-stat__logo--ccl) {
      height: 2.75rem;
      width: auto;
      max-width: 5rem;
    }

    .footer-stat__logo--china {
      height: 2.75rem;
      width: 2.75rem;
    }

    .footer-stat__value {
      min-height: 2.75rem;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: clamp(2rem, 2.8vw, 2.75rem);
    }

    .footer-stat__label {
      font-size: clamp(0.8125rem, 1vw, 0.9375rem);
    }

    .footer-copy {
      justify-self: center;
      align-self: center;
      max-width: none;
      margin-top: clamp(1.5rem, 3vw, 2.5rem);
      text-align: center;
      font-size: 0.875rem;
      color: rgba(255, 255, 255, 0.5);
    }
  }
</style>
