---
const beforeItems = [
  'No sabes qué producto importar.',
  'No sabes cómo contactar proveedores.',
  'Tienes miedo a perder tu dinero.',
  'No conoces los procesos y todo te parece confuso.',
  'Tu negocio no avanza.',
];

const afterItems = [
  'Encuentras productos rentables.',
  'Contactas fácilmente con proveedores confiables.',
  'Calculas costos reales y aumentas tu margen de ganancia.',
  'Importas sin riesgo ni complicaciones.',
  'Empiezas a potenciar tu negocio.',
];
---

<section id="beneficios" class="site-section relative overflow-hidden">
  <img
    src="/images/sections/05-before-after/bg-puerto.png"
    alt=""
    class="pointer-events-none absolute inset-0 h-full w-full object-cover opacity-20"
    aria-hidden="true"
  />

  <div class="site-container relative">
    <div class="grid gap-6 lg:grid-cols-2 lg:gap-8">
      <div class="rounded-[20px] border border-white/15 bg-zinc-900/85 p-6 backdrop-blur-sm lg:p-10">
        <div class="mb-8 flex flex-col items-center gap-4 text-center">
          <img src="/images/sections/05-before-after/icon-antes.svg" alt="" class="h-24 w-24 object-contain lg:h-36 lg:w-36" aria-hidden="true" />
          <h3 class="font-sora text-2xl font-bold text-white/70 md:text-3xl lg:text-4xl xl:text-5xl">Antes del curso</h3>
        </div>
        <ul class="space-y-4 lg:space-y-5">
          {beforeItems.map((item) => (
            <li class="flex items-start gap-3 font-epilogue text-sm text-white/80 lg:gap-4 lg:text-lg">
              <img src="/images/sections/05-before-after/bullet-negativo.svg" alt="" class="mt-1 h-5 w-5 shrink-0 object-contain lg:h-6 lg:w-6" aria-hidden="true" />
              {item}
            </li>
          ))}
        </ul>
      </div>

      <div class="rounded-[20px] border border-probusiness-naranja/50 bg-probusiness-naranja/10 p-6 backdrop-blur-sm lg:p-10">
        <div class="mb-8 flex flex-col items-center gap-4 text-center">
          <img src="/images/sections/05-before-after/icon-despues.svg" alt="" class="h-24 w-24 object-contain lg:h-36 lg:w-36" aria-hidden="true" />
          <h3 class="font-sora text-2xl font-bold text-probusiness-naranja md:text-3xl lg:text-4xl xl:text-5xl">Después del curso</h3>
        </div>
        <ul class="space-y-4 lg:space-y-5">
          {afterItems.map((item) => (
            <li class="flex items-start gap-3 font-epilogue text-sm text-white lg:gap-4 lg:text-lg">
              <img src="/images/sections/05-before-after/bullet-positivo.svg" alt="" class="mt-1 h-5 w-5 shrink-0 object-contain lg:h-6 lg:w-6" aria-hidden="true" />
              {item}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
