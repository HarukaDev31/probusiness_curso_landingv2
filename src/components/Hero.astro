---
import ResponsiveImage from './ResponsiveImage.astro';
import { asset } from '../lib/assets';
---

<section id="inicio" class="relative overflow-hidden bg-black pt-[72px] lg:pt-[97px]">
  <ResponsiveImage
    src="/images/sections/02-hero/bg-hero-mobile.png"
    alt=""
    class="pointer-events-none absolute inset-0 h-full w-full object-cover object-center lg:hidden"
    sizes="100vw"
    aria-hidden="true"
    loading="eager"
  />
  <ResponsiveImage
    src="/images/sections/02-hero/bg-hero.png"
    alt=""
    class="pointer-events-none absolute inset-0 hidden h-full w-full object-cover opacity-50 lg:block"
    sizes="100vw"
    aria-hidden="true"
    loading="lazy"
  />
  <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-black/40 via-black/20 to-black lg:from-black/50 lg:via-black/30"></div>

  <div class="relative">
    <div class="site-container pb-8 lg:pb-12">
      <div class="relative lg:min-h-[580px] xl:min-h-[640px]">
        <!-- Imagen desktop (derecha) -->
        <div
          class="pointer-events-none absolute z-0 mt-[50px] hidden w-[50%] max-w-[700px] lg:block xl:right-[-1%] xl:w-[48%] xl:max-w-[720px]"
        >
          <ResponsiveImage
            src="/images/sections/02-hero/hero-cajas.png"
            alt="Profesionales celebrando una importación exitosa entre Perú y China"
            class="w-full object-contain"
            sizes="(max-width: 1023px) 90vw, 45vw"
            width="1790"
            height="1790"
            loading="eager"
            fetchpriority="high"
          />
        </div>

        <!-- Imagen móvil (arriba, Figma) -->
        <div class="hero-mobile-visual lg:hidden">
          <ResponsiveImage
            src="/images/sections/02-hero/hero-cajas.png"
            alt="Profesionales celebrando una importación exitosa entre Perú y China"
            class="hero-mobile-visual__img"
            sizes="90vw"
            width="1790"
            height="1790"
            loading="eager"
            fetchpriority="high"
          />
        </div>

        <!-- Contenido -->
        <div class="relative z-10 lg:max-w-[45%] xl:max-w-[45%]">
          <div
            class="badge-curso-vivo inline-flex h-9 items-center gap-1.5 rounded-[12px] px-3 sm:h-12 sm:gap-3 sm:px-5 lg:h-[58px] lg:gap-4 lg:rounded-[20px] lg:px-6"
          >
            <img
              src={asset('/images/sections/02-hero/icon-curso-vivo.svg')}
              alt=""
              class="h-5 w-5 shrink-0 lg:h-9 lg:w-9"
              width="60"
              height="60"
              aria-hidden="true"
            />
            <span class="font-sora text-[10px] font-medium tracking-wide text-white uppercase sm:text-sm lg:text-xl xl:text-2xl">
              CURSO EN VIVO
            </span>
          </div>

          <div class="mt-4 space-y-3 lg:mt-8 lg:space-y-5">
            <h1 class="hero-title font-sora font-semibold tracking-[-0.04em] text-white">
              <span class="font-medium">Aprende a importar </span>
              <br />
              <span class="font-medium">desde China y crea un </span>
              <br />
              <span class="font-medium">negocio rentable en </span>
              <br />
              <span class="font-medium">Perú</span>
            </h1>
            <p
              class="font-epilogue text-xs font-medium leading-snug text-white/90 sm:text-base lg:text-xl xl:text-[1.75rem] xl:leading-[1.26]"
            >
              Paso a paso, sin complicaciones y desde cero.
            </p>
          </div>

          <div class="hero-cards mt-5 grid grid-cols-3 gap-2 lg:mt-8 lg:gap-4">
            <div class="hero-card flex flex-row items-center lg:justify-between justify-center rounded-[10px] border border-white bg-black/40 p-1.5 backdrop-blur-sm lg:min-h-[90px] lg:justify-between lg:p-3.5 lg:px-4 lg:py-0">
              <div class="hero-card__icons flex flex-col items-center justify-center">
                <img src={asset('/images/sections/02-hero/icon-plane.svg')} alt="" class="h-3 w-3.5 shrink-0 object-contain lg:h-6 lg:w-6" aria-hidden="true" />
                <div class="flex flex-row items-end justify-center">
                  <img src={asset('/images/sections/02-hero/icon-ship.svg')} alt="" class="h-3 w-3.5 shrink-0 object-contain lg:h-6 lg:w-6" aria-hidden="true" />
                  <img src={asset('/images/sections/02-hero/icon-truck.svg')} alt="" class="h-3 w-3.5 shrink-0 object-contain lg:h-6 lg:w-6" aria-hidden="true" />
                </div>
              </div>
              <div class="hero-card__text font-epilogue leading-[0.93] text-white lg:text-base xl:text-lg">
                <p class="font-normal">Sin</p>
                <p class="font-medium">experiencia</p>
                <p class="font-normal">previa</p>
              </div>
            </div>

            <div class="hero-card flex flex-row items-center lg:justify-between justify-center rounded-[10px] border border-white bg-black/40 p-1.5 backdrop-blur-sm lg:min-h-[90px] lg:gap-2 lg:px-4 lg:py-0">
              <div class="hero-card__icons flex flex-wrap items-center justify-center">
                <img src={asset('/images/sections/02-hero/icon-peru.svg')} alt="" class="h-5 w-5 shrink-0 object-contain lg:h-14 lg:w-14" aria-hidden="true" />
              </div>
              <div class="hero-card__text font-epilogue leading-[0.93] text-white lg:text-base xl:text-lg">
                <p class="font-normal">Desde</p>
                <p class="font-medium">Perú</p>
                <p class="font-normal">sin viajar</p>
              </div>
            </div>

            <div class="hero-card hero-card--ccl flex flex-row items-center lg:justify-between justify-center rounded-[10px] border border-white bg-black/40 p-1.5 backdrop-blur-sm lg:min-h-[90px] lg:gap-2 lg:px-4 lg:py-0">
              <div class="hero-card__icons flex shrink-0 items-center">
                <ResponsiveImage src="/images/sections/02-hero/logo-ccl.png" alt="" class="h-5 w-auto object-contain lg:h-9" aria-hidden="true" responsive={false} />
              </div>
              <div class="hero-card__text font-epilogue leading-[0.93] text-white lg:text-base xl:text-lg">
                <p class="font-normal">Respaldado</p>
                <p class="font-normal">por la CCL</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @media (max-width: 1023px) {
    .hero-mobile-visual {
      position: relative;
      z-index: 0;
      display: flex;
      justify-content: center;
      margin-inline: clamp(-0.75rem, -3vw, -0.25rem);
      margin-bottom: clamp(1rem, 4vw, 1.5rem);
    }

    .hero-mobile-visual__img {
      width: 100%;
      max-width: min(100%, 26rem);
      object-fit: contain;
    }
  }

  .hero-title {
    font-size: clamp(1.35rem, 4.6vw, 1.85rem);
    line-height: 1.05;
  }

  @media (min-width: 1024px) {
    .hero-title {
      font-size: clamp(1.65rem, 3.5vw, 3.5rem);
    }
  }

  @media (max-width: 1023px) {
    .hero-card {
      min-height: 3.25rem;
      gap: 0.1rem;
      padding: 0.25rem 0.2rem;
    }

    .hero-card__text {
      font-size: 0.5rem;
      line-height: 0.88;
    }

    .hero-card__text p {
      margin: 0;
      line-height: 0.9;
    }

    .hero-card__icons {
      transform: scale(0.78);
    }

    .hero-card--ccl .hero-card__text {
      text-align: left;
    }
  }

  @media (min-width: 640px) and (max-width: 1023px) {
    .hero-card__text {
      font-size: 0.5625rem;
    }

    .hero-mobile-visual__img {
      max-width: 22rem;
    }
  }

  @media (min-width: 1024px) {
    .hero-cards {
      grid-template-columns: minmax(0, 514fr) minmax(0, 514fr) minmax(0, 570fr);
    }

    .hero-card {
      min-height: 5rem;
      padding: 0.875rem;
      gap: 0.375rem;
    }

    .hero-card__text {
      font-size: 0.75rem;
    }
  }

  @media (min-width: 1280px) {
    .hero-card__text {
      font-size: 1.125rem;
    }
  }
</style>
