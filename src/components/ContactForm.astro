<section id="contacto" class="site-section relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-t from-probusiness-naranja/10 to-transparent"></div>

  <div class="site-container relative">
    <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
      <div class="relative hidden min-h-[420px] lg:block xl:min-h-[500px]">
        <img
          src="/images/sections/13-contact/caja-producto.png"
          alt=""
          class="absolute bottom-0 left-0 w-[85%] max-w-lg object-contain"
          aria-hidden="true"
          loading="lazy"
        />
      </div>

      <div>
        <h2 class="mb-8 font-sora text-3xl font-bold leading-tight text-white md:text-4xl lg:mb-10 lg:text-5xl">
          Tu próxima importación, cada vez más cerca
        </h2>

        <form class="space-y-5" id="contact-form">
          <div>
            <label for="nombre" class="mb-2 block font-epilogue text-sm font-medium text-white/80">Nombre Completo</label>
            <input
              type="text"
              id="nombre"
              name="nombre"
              placeholder="e.g José Gutiérrez"
              class="w-full rounded-[20px] border border-white/15 bg-white/5 px-5 py-4 font-epilogue text-white placeholder:text-white/35 focus:border-probusiness-naranja focus:outline-none lg:px-6 lg:py-5"
            />
          </div>

          <div>
            <label for="whatsapp" class="mb-2 block font-epilogue text-sm font-medium text-white/80">Número de WhatsApp</label>
            <input
              type="tel"
              id="whatsapp"
              name="whatsapp"
              placeholder="999 999 999"
              class="w-full rounded-[20px] border border-white/15 bg-white/5 px-5 py-4 font-epilogue text-white placeholder:text-white/35 focus:border-probusiness-naranja focus:outline-none lg:px-6 lg:py-5"
            />
          </div>

          <div>
            <label for="email" class="mb-2 block font-epilogue text-sm font-medium text-white/80">Correo electrónico</label>
            <input
              type="email"
              id="email"
              name="email"
              placeholder="jgutierrezl@example.com"
              class="w-full rounded-[20px] border border-white/15 bg-white/5 px-5 py-4 font-epilogue text-white placeholder:text-white/35 focus:border-probusiness-naranja focus:outline-none lg:px-6 lg:py-5"
            />
          </div>

          <div>
            <label for="experiencia" class="mb-2 block font-epilogue text-sm font-medium text-white/80">¿Tienes experiencia importando?</label>
            <select
              id="experiencia"
              name="experiencia"
              class="w-full appearance-none rounded-[20px] border border-white/15 bg-white/5 px-5 py-4 font-epilogue text-white focus:border-probusiness-naranja focus:outline-none lg:px-6 lg:py-5"
            >
              <option value="" class="bg-black">Selecciona una opción</option>
              <option value="si" class="bg-black">Sí, tengo experiencia</option>
              <option value="no" class="bg-black">No, soy principiante</option>
              <option value="poca" class="bg-black">Tengo poca experiencia</option>
            </select>
          </div>

          <button
            type="submit"
            class="btn-primary w-full rounded-[20px] py-4 font-epilogue text-xl font-bold text-white lg:py-5 lg:text-2xl"
          >
            Inscribirme ahora
          </button>

          <p id="form-success" class="hidden text-center font-epilogue text-sm text-probusiness-naranja">
            ¡Gracias! Un asesor te contactará pronto.
          </p>
          <p class="text-center font-epilogue text-sm text-white/60">
            Un asesor te contactará para confirmar tu inscripción
          </p>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  document.getElementById('contact-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const success = document.getElementById('form-success');
    success?.classList.remove('hidden');
    (e.target as HTMLFormElement).reset();
  });
</script>
