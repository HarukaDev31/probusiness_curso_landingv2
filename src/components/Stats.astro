---
import ResponsiveImage from './ResponsiveImage.astro';
import { asset, videoAsset } from '../lib/assets';

const statsVideo = videoAsset('/videos/landing-02.mp4');
---

<section class="site-section relative isolate overflow-hidden">
  <div class="pointer-events-none absolute inset-x-0 top-1/2 z-0 h-[80%] -translate-y-1/2" aria-hidden="true">
    <ResponsiveImage
      src="/images/sections/03-video-stats/bg-wave.png"
      alt=""
      class="h-full w-full object-cover opacity-55"
      sizes="100vw"
      loading="lazy"
      aria-hidden="true"
    />
    <div class="absolute inset-y-0 left-0 w-[18%] bg-gradient-to-r from-black via-black/70 to-transparent"></div>
    <div class="absolute inset-y-0 right-0 w-[18%] bg-gradient-to-l from-black via-black/70 to-transparent"></div>
    <div class="absolute inset-x-0 top-0 h-[22%] bg-gradient-to-b from-black via-black/75 to-transparent"></div>
    <div class="absolute inset-x-0 bottom-0 h-[22%] bg-gradient-to-t from-black via-black/75 to-transparent"></div>
  </div>

  <!-- Mobile (Figma) -->
  <div class="site-container relative z-10 flex flex-col gap-5 lg:hidden">
    <div class="flex items-center gap-2">
      <span class="font-sora text-2xl font-medium tracking-[-0.04em] text-[#ff6a29]">Clase</span>
      <span class="rounded-sm bg-probusiness-naranja px-1.5 py-0.5 font-sora text-xl font-medium tracking-[-0.04em] text-white">PRO</span>
    </div>

    <h2 class="font-epilogue text-[clamp(1.75rem,6vw,2.25rem)] leading-[1.03] tracking-[-0.03em] text-white">
      <span class="font-medium">¿Por qué</span>
      <span class="font-normal"> importar</span>
      <br />
      <span class="font-normal"> de China?</span>
    </h2>

    <div class="flex items-center gap-2">
      <img
        src={asset('/images/sections/02-hero/icon-play-classbar.svg')}
        alt=""
        class="h-8 w-8 shrink-0 object-contain"
        width="116"
        height="116"
        aria-hidden="true"
      />
      <span class="font-epilogue text-base font-medium text-white">
        Ver <span class="font-semibold">clase gratuita</span>
      </span>
    </div>

    <div id="video-mobile" class="relative w-full">
      <video
        class="stats-video aspect-video w-full rounded-[10px] bg-black object-cover"
        src={statsVideo}
        controls
        playsinline
        preload="metadata"
        controlslist="nodownload"
        title="Clase gratuita ProBusiness"
      />
    </div>

    <div class="stats-mobile-grid grid grid-cols-3 divide-x divide-white/30">
      <div class="flex flex-col items-center px-1 py-2 text-center">
        <img
          src={asset('/images/sections/03-video-stats/icon-experiencia.svg')}
          alt=""
          class="mb-2 h-11 w-11 object-contain"
          aria-hidden="true"
        />
        <p class="font-sora text-xl font-normal leading-none text-white">+10</p>
        <p class="mt-1 font-epilogue text-[0.65rem] leading-tight text-white/80">
          Años de<br />experiencia
        </p>
      </div>

      <div class="flex flex-col items-center px-1 py-2 text-center">
        <img
          src={asset('/images/sections/03-video-stats/icon-alumnos.svg')}
          alt=""
          class="mb-2 h-11 w-11 object-contain"
          aria-hidden="true"
        />
        <p class="font-sora text-xl font-normal leading-none text-white">+5K</p>
        <p class="mt-1 font-epilogue text-[0.65rem] leading-tight text-white/80">
          Alumnos<br />Formados
        </p>
      </div>

      <div class="flex flex-col items-center px-1 py-2 text-center">
        <img
          src={asset('/images/sections/03-video-stats/icon-importaciones.svg')}
          alt=""
          class="mb-2 h-11 w-11 object-contain"
          aria-hidden="true"
        />
        <p class="font-sora text-xl font-normal leading-none text-white">+500</p>
        <p class="mt-1 font-epilogue text-[0.65rem] leading-tight text-white/80">
          Importaciones<br />realizadas
        </p>
      </div>
    </div>

    <a
      href="#contacto"
      class="stats-mobile-cta btn-primary inline-flex w-full items-center justify-center rounded-[5px] font-epilogue font-bold text-white"
    >
      Quiero empezar ahora
    </a>
  </div>

  <!-- Desktop -->
  <div class="site-container relative z-10 hidden grid-cols-3 gap-10 lg:grid">
    <div class="col-span-2">
      <div class="flex items-center gap-2">
        <img
          src={asset('/images/sections/02-hero/icon-play-classbar.svg')}
          alt=""
          class="h-10 w-10 shrink-0 object-contain xl:h-[40px] xl:w-[40px]"
          width="116"
          height="116"
          aria-hidden="true"
        />
        <span class="font-epilogue text-xl text-white xl:text-[1.5rem] xl:leading-[1.18]">
          Ver <span class="font-semibold">clase gratuita</span>
        </span>
      </div>
      <div class="mt-4 w-full">
        <div id="video" class="relative w-[95%] rounded-[20px]">
          <video
            class="stats-video h-[700px] w-full rounded-[10px] bg-black object-cover"
            src={statsVideo}
            controls
            playsinline
            preload="metadata"
            controlslist="nodownload"
            title="Clase gratuita ProBusiness"
          />
        </div>
      </div>
    </div>

    <div class="relative col-span-1 space-y-10">
      <div class="relative z-10">
        <div class="mb-4 flex items-center gap-2 py-0">
          <span class="font-sora text-4xl font-medium tracking-[-0.04em] text-[#ff6a29] xl:text-[3.5rem] xl:leading-[1.03]">
            Clase
          </span>
          <span class="bg-probusiness-naranja px-1 font-sora text-5xl font-medium tracking-[-0.04em] text-white xl:text-[3rem] xl:leading-[1.03]">
            PRO
          </span>
        </div>
        <h2 class="font-epilogue text-4xl leading-[1.03] tracking-[-0.03em] text-white">
          <span class="font-medium">¿Por qué</span>
          <span class="font-normal"> importar</span>
          <br />
          <span class="font-normal"> de China?</span>
        </h2>

        <div class="w-[80%] min-w-[300px] divide-y divide-white/85">
          <div class="flex items-center gap-2 py-8 first:pt-0 last:pb-0">
            <img
              src={asset('/images/sections/03-video-stats/icon-experiencia.svg')}
              alt=""
              class="h-20 w-20 shrink-0 object-contain xl:h-24 xl:w-24"
              aria-hidden="true"
            />
            <div>
              <p class="font-sora text-4xl font-normal xl:text-5xl">+10 años</p>
              <p class="font-epilogue text-2xl text-white/80">De experiencia</p>
            </div>
          </div>

          <div class="flex items-center gap-2 py-8 first:pt-0 last:pb-0">
            <img
              src={asset('/images/sections/03-video-stats/icon-alumnos.svg')}
              alt=""
              class="h-20 w-20 shrink-0 object-contain xl:h-24 xl:w-24"
              aria-hidden="true"
            />
            <div>
              <p class="font-sora text-4xl font-normal xl:text-5xl">+5.000</p>
              <p class="font-epilogue text-2xl text-white/80">Alumnos formados</p>
            </div>
          </div>

          <div class="flex items-center gap-2 py-8 first:pt-0 last:pb-0">
            <img
              src={asset('/images/sections/03-video-stats/icon-importaciones.svg')}
              alt=""
              class="h-20 w-20 shrink-0 object-contain xl:h-24 xl:w-24"
              aria-hidden="true"
            />
            <div>
              <p class="font-sora text-4xl font-normal xl:text-5xl">+500</p>
              <p class="font-epilogue text-2xl text-white/80">Importaciones</p>
              <p class="font-epilogue text-2xl text-white/80">realizadas</p>
            </div>
          </div>
        </div>

        <a
          href="#contacto"
          class="btn-primary inline-flex w-[80%] min-w-[300px] items-center justify-center rounded-[5px] px-8 py-4 font-epilogue text-2xl font-bold text-white"
        >
          Quiero empezar ahora
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .stats-mobile-cta {
    padding: 0.85rem 1rem;
    font-size: clamp(1.25rem, 5vw, 1.5rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }
</style>
