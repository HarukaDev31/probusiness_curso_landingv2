---
import ResponsiveImage from './ResponsiveImage.astro';
import { asset, videoAsset } from '../lib/assets';

const statsVideo = videoAsset('/videos/landing-02.mp4');
---

<section class="site-section relative isolate overflow-hidden">
  <div class="pointer-events-none absolute inset-x-0 top-1/2 z-0 h-[80%] -translate-y-1/2" aria-hidden="true">
    <ResponsiveImage
      src="/images/sections/03-video-stats/bg-wave.png"
      alt=""
      class="h-full w-full object-cover opacity-55"
      sizes="100vw"
      loading="lazy"
      aria-hidden="true"
    />
    <div class="absolute inset-y-0 left-0 w-[18%] bg-gradient-to-r from-black via-black/70 to-transparent"></div>
    <div class="absolute inset-y-0 right-0 w-[18%] bg-gradient-to-l from-black via-black/70 to-transparent"></div>
    <div class="absolute inset-x-0 top-0 h-[22%] bg-gradient-to-b from-black via-black/75 to-transparent"></div>
    <div class="absolute inset-x-0 bottom-0 h-[22%] bg-gradient-to-t from-black via-black/75 to-transparent"></div>
  </div>

  <!-- Mobile (Figma) -->
  <div class="site-container relative z-10 flex flex-col gap-5 lg:hidden">
    <div class="flex items-center gap-2">
      <span class="font-sora text-2xl font-medium tracking-[-0.04em] text-[#ff6a29]">Clase</span>
      <span class="rounded-sm bg-probusiness-naranja px-1.5 py-0.5 font-sora text-xl font-medium tracking-[-0.04em] text-white">PRO</span>
    </div>

    <h2 class="font-epilogue text-[clamp(1.75rem,6vw,2.25rem)] leading-[1.03] tracking-[-0.03em] text-white">
      <span class="font-medium">Descubre</span>
      <br />
      <span class="font-normal"> tu potencial</span>
      <br />  
      <span class="font-normal"> como importador</span>
    </h2>

    <div class="flex items-center gap-2">
      <img
        src={asset('/images/sections/02-hero/icon-play-classbar.svg')}
        alt=""
        class="h-8 w-8 shrink-0 object-contain"
        width="116"
        height="116"
        aria-hidden="true"
      />
      <span class="font-epilogue text-base font-medium text-white">
        Ver <span class="font-semibold">clase gratuita</span>
      </span>
    </div>

    <div id="video-mobile" class="stats-video-wrap relative w-full">
      <video
        class="stats-video aspect-video w-full rounded-[10px] bg-black object-cover"
        src={statsVideo}
        playsinline
        preload="metadata"
        controlslist="nodownload"
        title="Clase gratuita ProBusiness"
        data-stats-video
      />
      <button
        type="button"
        class="stats-play-btn"
        aria-label="Reproducir clase gratuita"
        data-stats-play
      >
        <span class="stats-play-btn__circle">
          <img
            src={asset('/images/sections/03-video-stats/play-overlay.svg')}
            alt=""
            class="stats-play-btn__icon"
            aria-hidden="true"
          />
        </span>
        <span class="stats-play-btn__label font-epilogue font-semibold text-white">Reproducir</span>
      </button>
    </div>

    <div class="stats-mobile-grid grid grid-cols-3 divide-x divide-white/30">
      <div class="flex flex-col items-center px-1 py-2 text-center">
        <img
          src={asset('/images/sections/03-video-stats/icon-experiencia.svg')}
          alt=""
          class="mb-2 h-11 w-11 object-contain"
          aria-hidden="true"
        />
        <p class="font-sora text-xl font-normal leading-none text-white">+10</p>
        <p class="mt-1 font-epilogue text-[0.65rem] leading-tight text-white/80">
          Años de<br />experiencia
        </p>
      </div>

      <div class="flex flex-col items-center px-1 py-2 text-center">
        <img
          src={asset('/images/sections/03-video-stats/icon-alumnos.svg')}
          alt=""
          class="mb-2 h-11 w-11 object-contain"
          aria-hidden="true"
        />
        <p class="font-sora text-xl font-normal leading-none text-white">+5K</p>
        <p class="mt-1 font-epilogue text-[0.65rem] leading-tight text-white/80">
          Alumnos<br />Formados
        </p>
      </div>

      <div class="flex flex-col items-center px-1 py-2 text-center">
        <img
          src={asset('/images/sections/03-video-stats/icon-importaciones.svg')}
          alt=""
          class="mb-2 h-11 w-11 object-contain"
          aria-hidden="true"
        />
        <p class="font-sora text-xl font-normal leading-none text-white">+500</p>
        <p class="mt-1 font-epilogue text-[0.65rem] leading-tight text-white/80">
          Importaciones<br />realizadas
        </p>
      </div>
    </div>

    <a
      href="#contacto"
      class="stats-mobile-cta btn-primary mt-5 inline-flex w-full items-center justify-center rounded-[5px] font-epilogue font-bold text-white"
    >
      Quiero empezar ahora
    </a>
  </div>

  <!-- Desktop -->
  <div class="site-container relative z-10 hidden grid-cols-3 gap-10 lg:grid">
    <div class="col-span-2">
      <div class="flex items-center gap-2">
        <img
          src={asset('/images/sections/02-hero/icon-play-classbar.svg')}
          alt=""
          class="h-10 w-10 shrink-0 object-contain xl:h-[40px] xl:w-[40px]"
          width="116"
          height="116"
          aria-hidden="true"
        />
        <span class="font-epilogue text-xl text-white xl:text-[1.5rem] xl:leading-[1.18]">
          Ver <span class="font-semibold">clase gratuita</span>
        </span>
      </div>
      <div class="mt-4 w-full">
        <div id="video" class="stats-video-wrap relative w-[95%] rounded-[20px]">
          <video
            class="stats-video h-[700px] w-full rounded-[10px] bg-black object-cover"
            src={statsVideo}
            playsinline
            preload="metadata"
            controlslist="nodownload"
            title="Clase gratuita ProBusiness"
            data-stats-video
          />
          <button
            type="button"
            class="stats-play-btn"
            aria-label="Reproducir clase gratuita"
            data-stats-play
          >
            <span class="stats-play-btn__circle">
              <img
                src={asset('/images/sections/03-video-stats/play-overlay.svg')}
                alt=""
                class="stats-play-btn__icon"
                aria-hidden="true"
              />
            </span>
          </button>
        </div>
      </div>
    </div>

    <div class="relative col-span-1 space-y-10">
      <div class="relative z-10">
        <div class="mb-4 flex items-center gap-2 py-0">
          <span class="font-sora text-4xl font-medium tracking-[-0.04em] text-[#ff6a29] xl:text-[3.5rem] xl:leading-[1.03]">
            Clase
          </span>
          <span class="bg-probusiness-naranja px-1 font-sora text-5xl font-medium tracking-[-0.04em] text-white xl:text-[3rem] xl:leading-[1.03]">
            PRO
          </span>
        </div>
        <h2 class="font-epilogue text-4xl leading-[1.03] tracking-[-0.03em] text-white pb-4">
          <span class="font-medium">Descubre</span>
          <br />
          <span class="font-normal"> tu potencial</span>
          <br />
          <span class="font-normal"> como importador</span>
        </h2>

        <div class="w-[80%] min-w-[300px] divide-y divide-white/85">
          <div class="flex items-center gap-2 py-8 first:pt-0 last:pb-0">
            <img
              src={asset('/images/sections/03-video-stats/icon-experiencia.svg')}
              alt=""
              class="h-20 w-20 shrink-0 object-contain xl:h-24 xl:w-24"
              aria-hidden="true"
            />
            <div>
              <p class="font-sora text-4xl font-normal xl:text-5xl">+10 años</p>
              <p class="font-epilogue text-2xl text-white/80">De experiencia</p>
            </div>
          </div>

          <div class="flex items-center gap-2 py-8 first:pt-0 last:pb-0">
            <img
              src={asset('/images/sections/03-video-stats/icon-alumnos.svg')}
              alt=""
              class="h-20 w-20 shrink-0 object-contain xl:h-24 xl:w-24"
              aria-hidden="true"
            />
            <div>
              <p class="font-sora text-4xl font-normal xl:text-5xl">+5.000</p>
              <p class="font-epilogue text-2xl text-white/80">Alumnos formados</p>
            </div>
          </div>

          <div class="flex items-center gap-2 py-8 first:pt-0 last:pb-0">
            <img
              src={asset('/images/sections/03-video-stats/icon-importaciones.svg')}
              alt=""
              class="h-20 w-20 shrink-0 object-contain xl:h-24 xl:w-24"
              aria-hidden="true"
            />
            <div>
              <p class="font-sora text-4xl font-normal xl:text-5xl">+500</p>
              <p class="font-epilogue text-2xl text-white/80">Importaciones</p>
              <p class="font-epilogue text-2xl text-white/80">realizadas</p>
            </div>
          </div>
        </div>

        <a
          href="#contacto"
          class="btn-primary mt-5 inline-flex w-[80%] min-w-[300px] items-center justify-center rounded-[5px] px-8 py-4 font-epilogue text-2xl font-bold text-white"
        >
          Quiero empezar ahora
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  function initStatsVideoPlayers() {
    document.querySelectorAll('.stats-video-wrap').forEach((wrap) => {
      if (wrap.dataset.bound === 'true') return;
      wrap.dataset.bound = 'true';

      const video = wrap.querySelector('[data-stats-video]');
      const playBtn = wrap.querySelector('[data-stats-play]');
      if (!(video instanceof HTMLVideoElement) || !(playBtn instanceof HTMLButtonElement)) return;

      const hidePlay = () => wrap.classList.add('is-playing');
      const showPlay = () => wrap.classList.remove('is-playing');

      playBtn.addEventListener('click', () => {
        video.controls = true;
        video.play();
        hidePlay();
      });

      video.addEventListener('play', hidePlay);
      video.addEventListener('pause', () => {
        if (video.currentTime === 0 || video.ended) showPlay();
      });
      video.addEventListener('ended', showPlay);
    });
  }

  initStatsVideoPlayers();
  document.addEventListener('astro:page-load', initStatsVideoPlayers);
</script>

<style>
  .stats-video-wrap:not(.is-playing) .stats-video {
    pointer-events: none;
  }

  .stats-play-btn {
    position: absolute;
    inset: 0;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    border: none;
    background: rgba(0, 0, 0, 0.28);
    border-radius: inherit;
    cursor: pointer;
    transition: opacity 0.25s ease, background 0.25s ease;
  }

  .stats-video-wrap.is-playing .stats-play-btn {
    opacity: 0;
    pointer-events: none;
  }

  .stats-play-btn:hover {
    background: rgba(0, 0, 0, 0.38);
  }

  .stats-play-btn__circle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: clamp(4.5rem, 14vw, 6.5rem);
    height: clamp(4.5rem, 14vw, 6.5rem);
    border-radius: 9999px;
    background: linear-gradient(135deg, #ff5410 0%, #ff733b 100%);
    box-shadow:
      0 0 0 6px rgba(255, 106, 41, 0.28),
      0 8px 40px rgba(255, 84, 16, 0.65);
    transition: transform 0.2s ease;
  }

  .stats-play-btn:hover .stats-play-btn__circle {
    transform: scale(1.06);
  }

  .stats-play-btn__icon {
    width: 32%;
    height: 32%;
    margin-left: 6%;
    object-fit: contain;
  }

  .stats-play-btn__label {
    font-size: clamp(0.95rem, 2.5vw, 1.25rem);
    letter-spacing: 0.02em;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.55);
  }

  .stats-mobile-cta {
    padding: 0.85rem 1rem;
    font-size: clamp(1.25rem, 5vw, 1.5rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }
</style>
