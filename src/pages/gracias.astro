---
import Layout from '../layouts/Layout.astro';
import { asset } from '../lib/assets';

const homePath = '/#inicio';
const thanksTitle = 'Gracias — Pro Business';
const thanksDescription =
  'Registro al curso Pro Business: confirma los siguientes pasos y revisa tu correo para no perderte las clases en vivo.';
---

<Layout title={thanksTitle} description={thanksDescription}>
  <script define:vars={{ homePath }}>
    (function () {
      const SUCCESS_FLAG_KEY = 'leadFormConfirmed';
      const SUCCESS_AT_KEY = 'leadFormConfirmedAt';
      const ACCESS_TTL_MS = 10 * 60 * 1000;
      const hasConfirmed = sessionStorage.getItem(SUCCESS_FLAG_KEY) === '1';
      const confirmedAt = Number(sessionStorage.getItem(SUCCESS_AT_KEY) || '0');
      const isFresh =
        Number.isFinite(confirmedAt) && Date.now() - confirmedAt <= ACCESS_TTL_MS;

      if (!hasConfirmed || !isFresh) {
        window.location.replace(homePath);
        return;
      }

      document.documentElement.classList.add('thanks-authorized');
      sessionStorage.removeItem(SUCCESS_FLAG_KEY);
      sessionStorage.removeItem(SUCCESS_AT_KEY);
    })();
  </script>

  <main class="thanks-page">
    <section class="thanks-card-wrap">
      <article class="thanks-card">
        <img
          class="thanks-logo"
          src={asset('/images/sections/01-header/logo-full.png')}
          alt="Pro Business"
        />

        <div class="thanks-content">
          <img
            class="thanks-icon"
            src="https://cdn.probusiness.pe/landingcurso/figma/thanks/thanks-envelope-green.webp"
            alt="Mensaje recibido"
            width="260"
            height="260"
          />
          <div class="thanks-copy">
            <h1>Gracias por <span>registrarte</span></h1>
            <p>
              Nos alegra mucho que hayas dado este paso para seguir creciendo en el mundo de la
              importación y la logística. Te contactaremos a la brevedad posible.
            </p>
            <a class="thanks-home-btn" href={homePath}>Volver al Inicio</a>
          </div>
        </div>
      </article>
      <p class="thanks-footer">© 2026 Pro Business - Curso de Importacion desde China</p>
    </section>
  </main>
</Layout>

<style>
  .thanks-page {
    display: none;
    min-height: 100svh;
    background: #000;
    color: #fff;
    place-items: center;
    padding: 0;
  }

  :global(html.thanks-authorized) .thanks-page {
    display: grid;
  }

  .thanks-card-wrap {
    width: 100%;
  }

  .thanks-card {
    background: #050505;
    padding: clamp(18px, 3vw, 34px) clamp(16px, 4vw, 40px);
    min-height: 100svh;
    width: 100%;
    box-sizing: border-box;
  }

  .thanks-logo {
    display: block;
    width: clamp(120px, 18vw, 180px);
    height: auto;
    margin: 4px 0 clamp(24px, 5vw, 56px);
  }

  .thanks-content {
    width: min(1050px, 96%);
    margin: 0 auto;
    background: linear-gradient(125deg, #111f17 0%, #12261b 58%, #102117 100%);
    border-radius: 28px;
    display: grid;
    grid-template-columns: minmax(180px, 260px) 1fr;
    gap: clamp(20px, 5vw, 54px);
    align-items: center;
    padding: clamp(24px, 5vw, 52px);
    position: relative;
    overflow: hidden;
  }

  .thanks-content::after {
    content: '';
    position: absolute;
    width: 260px;
    height: 260px;
    right: -88px;
    top: -88px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(50, 221, 128, 0.55) 0%,
      rgba(50, 221, 128, 0) 70%
    );
    pointer-events: none;
  }

  .thanks-icon {
    justify-self: center;
    width: clamp(150px, 23vw, 250px);
    height: auto;
    display: block;
  }

  .thanks-copy h1 {
    margin: 0 0 14px;
    font-family: var(--font-sora);
    font-size: clamp(2rem, 5vw, 4rem);
    line-height: 0.98;
    letter-spacing: -0.02em;
    font-weight: 500;
  }

  .thanks-copy h1 span {
    color: #32dd80;
  }

  .thanks-copy p {
    margin: 0 0 24px;
    max-width: 36ch;
    font-family: var(--font-epilogue);
    color: #e6e6e6;
    font-size: clamp(1rem, 2vw, 1.6rem);
    line-height: 1.2;
  }

  .thanks-home-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 44px;
    padding: 0 18px;
    border-radius: 10px;
    border: none;
    text-decoration: none;
    background: linear-gradient(90deg, #25cf43 0%, #61fd7d 100%);
    color: #001607;
    font-family: var(--font-epilogue);
    font-size: 1.05rem;
    font-weight: 700;
    transition:
      transform 0.2s ease,
      filter 0.2s ease;
  }

  .thanks-home-btn:hover {
    transform: translateY(-1px);
    filter: brightness(1.06);
  }

  .thanks-home-btn:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 2px;
  }

  .thanks-footer {
    text-align: center;
    margin: 18px 0 0;
    color: #9a9a9a;
    font-family: var(--font-epilogue);
    font-size: 0.9rem;
  }

  @media (max-width: 840px) {
    .thanks-content {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .thanks-copy p {
      margin-inline: auto;
    }
  }
</style>
